        const tag=e.target.tagName.toLowerCase();

        if (tag==='input' || tag==='textarea' || tag==='select') {
            if(e.key==='Escape') {
                e.target.blur(); closeAllModals();
            }

            return;
        }

        if (e.ctrlKey || e.metaKey || e.altKey) return;

        switch(e.key.toLowerCase()) {
            case 'g':
            /* Generate */
            document.getElementById('exportBtn').click(); break;
            case 'f':
            /* File picker */
            document.getElementById('fileInput').click(); break;
            case 'c':
            /* Crop */
            document.getElementById('cropBtn').click(); break;
            case 't':
            /* Toggle theme */
            document.getElementById('themeToggle').click(); break;
            case 'escape': closeAllModals(); break;
            case '?': document.getElementById('shortcutsModal').style.display='flex'; break;
        }
    });

function closeAllModals() {
    document.querySelectorAll('.modal-overlay').forEach(m=> m.style.display='none');
}

