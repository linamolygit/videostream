/* ─── CURVE 1: Standard Spring (sabse zyada use hoti hai) ─── */
/* Use: Buttons, panels, zoom, any general transition */
transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
/*          ↑dur  ↑ease: fast start, overshoots slightly, settles smooth */


/* ─── CURVE 2: Bouncy Spring (iOS Toggle feel) ─── */
/* Use: Toggle thumb slide, popup appear, icon pop */
transition: 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
/*           ↑dur  ↑ease: goes BEYOND target then snaps back — "bouncy" */


/* ─── CURVE 3: Elastic Toast (notification slide-in) ─── */
/* Use: Toast notifications, confetti elements, success popups */
transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
/*                    ↑dur  ↑ease: starts slow, big overshoot, snaps */


/* ─── CURVE 4: Smooth Theme Change ─── */
/* Use: Dark/Light mode switch — colors change slowly & pleasantly */
transition: background-color 0.4s ease,
color 0.4s ease;


/* ─── CURVE 5: Quick Micro (very fast) ─── */
/* Use: Slider thumb scale, close button, small interactions */
transition: transform 0.2s;


/* ─── CURVE 6: Slow Smooth (large layout changes) ─── */
/* Use: Aspect ratio change, mockup wrapper resize */
transition: aspect-ratio 0.4s ease,
border-radius 0.4s ease;
